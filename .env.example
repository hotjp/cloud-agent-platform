# Cloud Agent Platform - Environment Configuration Template
# Copy to .env and fill in actual values

# Server
APP_SERVER_PORT=8080
APP_SERVER_METRICSPORT=9090
APP_SERVER_PPROFPORT=6060
APP_SERVER_READTIMEOUT=10s
APP_SERVER_WRITETIMEOUT=30s

# Database (PostgreSQL)
APP_DATABASE_DSN="postgres://user:password@localhost:5432/cloud_agent_platform?sslmode=disable"
APP_DATABASE_MAXOPEN=25
APP_DATABASE_MAXIDLE=10
APP_DATABASE_MAXLIFETIME=5m

# Redis
APP_REDIS_ADDR="localhost:6379"
APP_REDIS_PASSWORD=""
APP_REDIS_DB=0

# Auth
APP_AUTHZ_JWTSECRET="your-jwt-secret-here"
APP_AUTHZ_APIKEYHEADER="X-API-Key"
APP_AUTHZ_CACHETTL=5m

# Telemetry
APP_TELEMETRY_SERVICENAME="cloud-agent-platform"
APP_TELEMETRY_ENDPOINT="http://localhost:4317"
APP_TELEMETRY_SAMPLERATE=0.1

# LLM Providers
APP_LLM_ANTHROPICAPIKEY=""
APP_LLM_ZHIPUAPIKEY=""

# Worker Sandbox
APP_SANDBOX_BACKEND="docker"
APP_SANDBOX_FALLBACKTODOCKER=true

# MinIO (Object Storage)
APP_MINIO_ENDPOINT="localhost:9000"
APP_MINIO_ACCESSKEY=""
APP_MINIO_SECRETKEY=""
APP_MINIO_BUCKET="cap-artifacts"
APP_MINIO_USESSL=false

# Git
APP_GIT_HTTPSUSER=""
APP_GIT_HTTPSTOKEN=""

# Rate Limiting (sentinel-go)
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_QPS=100
APP_RATE_LIMIT_BURST=200
