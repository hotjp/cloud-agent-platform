# Cloud Agent Platform - Environment Configuration Template
# Copy to .env and fill in actual values

# Server
APP_SERVER_PORT=8080
APP_SERVER_METRICS_PORT=9090
APP_SERVER_PPROF_PORT=6060
APP_SERVER_READ_TIMEOUT=10s
APP_SERVER_WRITE_TIMEOUT=30s

# Database (PostgreSQL)
APP_DATABASE_DSN="postgres://user:password@localhost:5432/cloud_agent_platform?sslmode=disable"
APP_DATABASE_MAX_OPEN=25
APP_DATABASE_MAX_IDLE=10
APP_DATABASE_MAX_LIFETIME=5m

# Redis
APP_REDIS_ADDR="localhost:6379"
APP_REDIS_PASSWORD=""
APP_REDIS_DB=0

# Auth
APP_JWT_SECRET="your-jwt-secret-here"
APP_API_KEY_HEADER="X-API-Key"

# Telemetry
APP_TELEMETRY_SERVICE_NAME="cloud-agent-platform"
APP_TELEMETRY_ENDPOINT="http://localhost:4317"
APP_TELEMETRY_SAMPLE_RATE=0.1

# LLM Providers
APP_ANTHROPIC_API_KEY=""
APP_ZHIPU_API_KEY=""

# Worker Sandbox
APP_SANDBOX_BACKEND="docker"
APP_SANDBOX_FALLBACK_TO_DOCKER=true

# MinIO (Object Storage)
APP_MINIO_ENDPOINT="localhost:9000"
APP_MINIO_ACCESS_KEY=""
APP_MINIO_SECRET_KEY=""
APP_MINIO_BUCKET="cap-artifacts"
APP_MINIO_USE_SSL=false

# Git
APP_GIT_HTTPS_USER=""
APP_GIT_HTTPS_TOKEN=""

# Rate Limiting (sentinel-go)
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_QPS=100
APP_RATE_LIMIT_BURST=200
