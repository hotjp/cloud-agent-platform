# =============================================================================
# Cloud Agent Platform - Production Environment Variables
# =============================================================================
# Copy this file to .env and configure for your environment.
# All sensitive values should be set via environment variables in production.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_GRPC_PORT=9090
APP_PPROF_PORT=6060
APP_METRICS_PORT=9090

# Server resource limits
GOMAXPROCS=4
GOMEMLIMIT=2GiB

# -----------------------------------------------------------------------------
# PostgreSQL 15
# -----------------------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cloud_agent_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=100

# -----------------------------------------------------------------------------
# Redis 7
# -----------------------------------------------------------------------------
REDIS_PASSWORD=changeme
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# OpenTelemetry Collector
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=cloud-agent-platform
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=changeme
API_KEY_HEADER=X-API-Key

# -----------------------------------------------------------------------------
# External Services (optional)
# -----------------------------------------------------------------------------
# CLAUDE_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
